{
  "name": "block-oli",
  "private": true,
  "version": "0.1.17",
  "type": "module",
  "engines": {
    "npm": "please_use_pnpm_instead"
  },
  "devEngines": {
    "runtime": {
      "name": "node",
      "version": "24.17.0",
      "onFail": "download"
    },
    "packageManager": {
      "name": "pnpm",
      "version": "11.8.0",
      "onFail": "download"
    }
  },
  "packageManager": "pnpm@11.10.0",
  "scripts": {
    "dev": "vite",
    "build": "run-s build:*",
    "build:schema": "run-s build:schema:*",
    "build:schema:quicktype": "quicktype src/modules/core/rules.ts -o src/schemas/draft.json --lang schema",
    "build:schema:merge": "node src/schemas/merge.js",
    "build:src": "tsc && vite build",
    "publish": "run-s build test",
    "lint": "eslint src --ext ts,tsx --report-unused-disable-directives --max-warnings 0",
    "preview": "vite preview",
    "test": "vitest --no-watch",
    "test:watch": "vitest --watch",
    "test:unit": "vitest --no-watch --project=unit",
    "test:browser": "vitest --no-watch --project=browser",
    "test:update-snapshots": "vitest --no-watch --project=browser --update",
    "test:coverage": "vitest --run --coverage",
    "test:coverage:report": "open \"file://$(pwd)/coverage/index.html\"",
    "docker:test:browser": "docker compose -f test/compose.yml run --build --rm test pnpm test:browser",
    "docker:test:update-snapshots": "docker compose -f test/compose.yml run --build --rm test pnpm test:update-snapshots",
    "coverage": "vitest run --coverage"
  },
  "dependencies": {
    "@chakra-ui/react": "^3.35.0",
    "@emotion/react": "^11.14.0",
    "chakra-react-select": "^6.1.1",
    "loglevel": "^1.9.2",
    "loglevel-plugin-prefix": "^0.8.4",
    "react": "^19.2.5",
    "react-dom": "^19.2.5",
    "react-icons": "^5.6.0",
    "react-transition-group": "^4.4.5"
  },
  "devDependencies": {
    "@crxjs/vite-plugin": "^2.4.0",
    "@eslint/js": "^10.0.1",
    "@testing-library/react": "^16.3.2",
    "@types/chrome": "^0.2.0",
    "@types/lodash-es": "^4.17.12",
    "@types/node": "^25.6.0",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@types/react-transition-group": "^4.4.12",
    "@typescript-eslint/eslint-plugin": "^8.59.1",
    "@typescript-eslint/parser": "^8.59.1",
    "@vitejs/plugin-react": "^6.0.1",
    "@vitest/browser": "^4.1.5",
    "@vitest/browser-playwright": "^4.1.5",
    "@vitest/coverage-v8": "^4.1.5",
    "ajv": "^8.20.0",
    "deepmerge": "^4.3.1",
    "eslint": "^10.3.0",
    "eslint-plugin-import-x": "^4.16.2",
    "eslint-plugin-react-hooks": "^7.1.1",
    "eslint-plugin-react-refresh": "^0.5.2",
    "fast-check": "^4.8.0",
    "globals": "^17.6.0",
    "happy-dom": "^20.9.0",
    "lodash-es": "^4.18.1",
    "npm-run-all2": "^9.0.2",
    "playwright": "^1.59.1",
    "quicktype": "^23.2.6",
    "sass-embedded": "^1.99.0",
    "typescript": "^6.0.3",
    "typescript-eslint": "^8.59.1",
    "vite": "^8.0.10",
    "vite-plugin-zip-pack": "^1.2.4",
    "vitest": "^4.1.5",
    "vitest-browser-react": "^2.2.0"
  }
}
